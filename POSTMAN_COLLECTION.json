              "raw": "{{base_url}}/api/listings?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "listings"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
