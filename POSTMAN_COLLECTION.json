                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"iPhone 13\",\n  \"description\": \"Excellent condition\",\n  \"categoryId\": \"uuid-here\",\n  \"price\": 150000,\n  \"condition\": \"good\",\n  \"location\": \"Lagos, Nigeria\",\n  \"images\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/listings",
              "host": ["{{base_url}}"],
